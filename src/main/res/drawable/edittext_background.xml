<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Sets the background color of the EditText -->
    <solid android:color="#F0F0F0" />

    <!-- Defines the border color and width -->
    <stroke
        android:width="1dp"
        android:color="#CCCCCC" />

    <!-- Adds rounded corners to the EditText -->
    <corners android:radius="8dp" />

    <!-- Adds padding inside the EditText -->
    <padding
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp" />

</shape>
    